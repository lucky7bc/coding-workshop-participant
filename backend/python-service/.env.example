PORT=4000

# Workshop Lambda environment contract (docs/full-stack.md). In the real
# deployed/LocalStack environment these five + IS_LOCAL are injected
# automatically per service — this file is only for direct local testing
# via `python -m app.main` outside the start-dev.sh/Terraform pipeline.
IS_LOCAL=true
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_NAME=
MONGO_USER=
MONGO_PASS=

JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
